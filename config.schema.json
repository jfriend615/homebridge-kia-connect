{
  "pluginAlias": "KiaConnect",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "customUiPath": "./dist/homebridge-ui",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Kia Connect",
        "required": true
      },
      "username": {
        "title": "Kia Connect Email",
        "type": "string",
        "required": true
      },
      "password": {
        "title": "Kia Connect Password",
        "type": "string",
        "required": true
      },
      "pollIntervalMinutes": {
        "title": "Poll Interval (minutes)",
        "type": "integer",
        "default": 30,
        "minimum": 5
      },
      "showLock": {
        "title": "Show Door Lock",
        "type": "boolean",
        "default": true
      },
      "showClimate": {
        "title": "Show Remote Start",
        "type": "boolean",
        "default": true
      },
      "showStatus": {
        "title": "Show Vehicle Sensors",
        "type": "boolean",
        "default": true,
        "description": "Fuel level, low fuel warning, outside temperature, engine running, and tire pressure."
      },
      "showBody": {
        "title": "Show Body Sensors",
        "type": "boolean",
        "default": false,
        "description": "Expose door, window, hood, and trunk sensors."
      },
      "showBattery": {
        "title": "Show 12V Battery",
        "type": "boolean",
        "default": true
      },
      "climateTemperature": {
        "title": "Remote Start Temperature (°F)",
        "type": "integer",
        "default": 72,
        "minimum": 62,
        "maximum": 82,
        "description": "Target temperature when starting climate control remotely."
      },
      "vehicleIndex": {
        "title": "Vehicle Index",
        "type": "integer",
        "default": 0,
        "minimum": 0,
        "description": "If you have multiple vehicles, specify the index (0 = first vehicle)"
      }
    }
  },
  "layout": [
    { "key": "name" },
    { "key": "username" },
    { "key": "password" },
    { "key": "pollIntervalMinutes" },
    { "key": "vehicleIndex" },
    {
      "type": "fieldset",
      "title": "Accessory Visibility",
      "expandable": true,
      "items": [
        "showLock",
        "showClimate",
        "showStatus",
        "showBody",
        "showBattery"
      ]
    },
    { "key": "climateTemperature" }
  ]
}
